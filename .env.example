# ===== 后端 apps/server（pydantic-settings 读取，前缀 WORKNEXUS_） =====
WORKNEXUS_DATABASE_URL=postgresql+asyncpg://worknexus:worknexus@localhost:5432/worknexus
WORKNEXUS_SECRET_KEY=change-me-in-production
WORKNEXUS_ENVIRONMENT=development

# 已有 AI 平台（multirag）对接
WORKNEXUS_AI_PLATFORM_BASE_URL=http://localhost:8123
WORKNEXUS_AI_PLATFORM_API_KEY=

# MCP 暴露层
WORKNEXUS_MCP_AUTH_TOKEN=change-me-mcp-token

# ===== 前端 apps/web（Vite，仅 VITE_ 前缀会注入客户端） =====
VITE_API_BASE_URL=http://localhost:8200/api/v1
